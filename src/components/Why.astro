---
const items = [
  { n: "一", h: "Ngọt tự nhiên", p: "Chỉ vị ngọt tự củ khoai nướng chậm. Không đường tinh luyện, không phụ gia." },
  { n: "二", h: "Mộc mạc, thủ công", p: "Làm theo mẻ đông á: ít bước, tôn nguyên liệu, giữ trọn hương đất." },
  { n: "三", h: "Không phẩm màu", p: "Màu vàng cam là của chính củ khoai — không nhuộm, không tạo màu." },
];
---
<section id="why" class="mx-auto max-w-page px-8 py-24">
  <div class="text-center mb-14">
    <div class="font-serif text-[13px] tracking-[0.3em] uppercase text-accent">余白 · 素朴</div>
    <h2 class="font-serif font-semibold text-[clamp(28px,4vw,42px)] mt-3">Vì sao là Goguma</h2>
    <div class="w-[46px] h-[3px] bg-accent mx-auto mt-4"></div>
  </div>
  <div class="grid md:grid-cols-3 gap-8">
    {items.map((it) => (
      <div class="bg-white/40 border border-ink/10 p-10 rounded hover:-translate-y-1 hover:shadow-xl hover:shadow-ink/5 transition">
        <div class="font-serif text-3xl text-accent/50">{it.n}</div>
        <h3 class="font-serif font-semibold text-xl mt-3 mb-2.5">{it.h}</h3>
        <p class="text-[15px] text-ink-soft">{it.p}</p>
      </div>
    ))}
  </div>
</section>
